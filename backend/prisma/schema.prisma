// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(cuid())
  email    String   @unique
  name     String?
  password String // bcrypt hash
  role     UserRole @default(CUSTOMER)

  // Autenticacao
  emailVerified            Boolean   @default(false)
  emailVerificationToken   String?   @unique
  emailVerificationExpires DateTime?

  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?

  lastLoginAt DateTime?

  cpf   String? @unique
  phone String?

  isActive Boolean @default(true)

  addresses        Address[]
  orders           Order[]
  wishlist         WishlistItem[]
  refreshTokens    RefreshToken[]
  reviews          Review[]
  exclusiveCoupons Coupon[] @relation("ExclusiveCoupons")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?

  createdAt DateTime @default(now())

  @@index([token])
  @@map("refresh_tokens")
}

enum UserRole {
  ADMIN
  CUSTOMER
}

model Address {
  id           String  @id @default(cuid())
  userId       String
  user         User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  postalCode   String
  country      String  @default("BR")
  isDefault    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("addresses")
}

model Order {
  id     String      @id @default(cuid())
  userId String
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  number String      @unique // ex: ORD-2026-001
  status OrderStatus @default(PENDING)

  items         OrderItem[]
  statusHistory OrderStatusHistory[]

  subtotal Float // antes de frete e cupom
  shipping Float @default(0)
  discount Float @default(0)
  total    Float // calculado

  shippingAddress     String? // JSON serializado
  shippingServiceName String? // Nome do serviço (ex: "PAC", "SEDEX")
  trackingCode        String?

  couponId String?

  paymentMethod String?        // mercado_pago, credit_card, pix, etc
  paymentStatus PaymentStatus @default(PENDING)
  paymentId     String?       // ID externo do gateway

  notes         String?
  stockReserved Boolean @default(false) // true se estoque foi reservado (idempotência)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentStatus {
  PENDING
  APPROVED
  FAILED
  CANCELLED
}

model OrderItem {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variationId String?
  variation   ProductVariation? @relation(fields: [variationId], references: [id])

  quantity Int
  price    Float // preco unitario no momento da compra
  discount Float @default(0)

  createdAt DateTime @default(now())

  @@map("order_items")
}

model Product {
  id               String  @id @default(cuid())
  name             String
  slug             String  @unique
  description      String
  shortDescription String?
  content          String? // descricao longa, HTML
  type             String  @default("simple") // "simple" ou "variable"

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  brandId String?
  brand   Brand? @relation(fields: [brandId], references: [id], onDelete: SetNull)

  basePrice Float // preco base, sem escala
  salePrice Float? // preco promocional

  // Inventario
  sku               String?  @unique
  gtin              String?
  manageStock       Boolean  @default(true)
  stock             Int      @default(0)
  reservedStock     Int      @default(0)
  lowStockThreshold Int? // override global; null = usar Setting low_stock_threshold
  weight      Float? // kg
  width       Float? // cm
  height      Float? // cm
  length      Float? // cm

  // Entrega
  extraDays Int? // dias adicionais (override categoria/tag)

  // Status
  isActive Boolean @default(true)
  featured Boolean @default(false)

  // Relacoes
  tags              Tag[]              @relation("ProductToTag")
  variations        ProductVariation[]
  images            ProductImage[]
  attributes        ProductAttribute[]
  relatedProducts   RelatedProduct[]   @relation("ProductRelated")
  reviews           Review[]
  stockAuditLogs    StockAuditLog[]

  orderItems    OrderItem[]
  wishlistItems WishlistItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([categoryId])
  @@index([brandId])
  @@index([slug])
  @@map("products")
}

model ProductVariation {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  name      String // ex: "Heroic Scale (28mm)"
  scaleId   String
  scale     Scale  @relation(fields: [scaleId], references: [id])

  sku       String
  gtin      String?
  price         Float // preco com ajuste de escala
  salePrice     Float?
  stock         Int   @default(0)
  reservedStock Int   @default(0)
  image         String? // URL imagem da variacao

  weight Float? // kg
  width  Float? // cm
  height Float? // cm
  length Float? // cm

  orderItems     OrderItem[]
  stockAuditLogs StockAuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, scaleId])
  @@index([scaleId])
  @@map("product_variations")
}

model MediaFile {
  id       String @id @default(cuid())
  filename String // nome original do arquivo
  mimeType String // image/jpeg, image/png, etc.
  size     Int // bytes do original

  // URLs das variantes WebP
  thumb   String // 150px — thumbnails, admin
  card    String // 400px — product cards
  gallery String // 800px — galeria principal
  full    String // 1600px — zoom/lightbox

  // SEO
  alt         String? // texto alternativo (acessibilidade + SEO)
  title       String? // titulo da imagem (hover)
  description String? // descricao longa (SEO)

  // Metadata original
  width  Int? // largura original
  height Int? // altura original

  productImages ProductImage[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("media_files")
}

model ProductImage {
  id          String    @id @default(cuid())
  productId   String
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  mediaFileId String
  mediaFile   MediaFile @relation(fields: [mediaFileId], references: [id], onDelete: Cascade)

  order  Int     @default(0)
  isMain Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([productId])
  @@map("product_images")
}

model Category {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  description String?
  image       String? // URL em R2

  parentId String?
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: SetNull)
  children Category[] @relation("CategoryToCategory")

  products Product[]
  coupons  Coupon[]

  isActive  Boolean @default(true)
  extraDays Int? // dias adicionais de produção

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("categories")
}

model Tag {
  id    String  @id @default(cuid())
  name  String  @unique
  slug  String  @unique
  color String? // hex color

  products Product[] @relation("ProductToTag")
  coupons  Coupon[]

  isActive  Boolean @default(true)
  extraDays Int? // dias adicionais de produção

  createdAt DateTime @default(now())

  @@index([slug])
  @@map("tags")
}

model Brand {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  logo        String? // URL em R2
  description String?

  products Product[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("brands")
}

model Scale {
  id         String  @id @default(cuid())
  name       String  @unique // ex: "Heroic Scale (28mm)"
  code       String  @unique // ex: "HEROIC_28"
  baseSize   Float // tamanho base em mm
  multiplier Float @default(1.0) // multiplicador de preco
  priority   Int   @default(0) // para ordenacao

  variations ProductVariation[]
  scaleRules ScaleRule[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())

  @@index([code])
  @@map("scales")
}

model ScaleRule {
  id      String @id @default(cuid())
  scaleId String
  scale   Scale  @relation(fields: [scaleId], references: [id], onDelete: Cascade)

  appliesTo RuleScope // PRODUCT, TAG, CATEGORY, GLOBAL
  targetId  String? // ID do produto, tag ou categoria

  priceMultiplier Float @default(1.0)
  stockMultiplier Float @default(1.0)

  priority Int @default(0)

  createdAt DateTime @default(now())

  @@map("scale_rules")
}

enum RuleScope {
  GLOBAL
  CATEGORY
  TAG
  PRODUCT
}

model Coupon {
  id   String     @id @default(cuid())
  code String     @unique // uppercase
  type CouponType

  value         Float // percentual ou valor fixo
  minOrderValue Float? // valor minimo do pedido
  maxUses       Int? // maximo de usos totais
  usesPerUser   Int? // maximo de usos por usuario

  validFrom DateTime?
  validUntil DateTime?

  isFirstPurchaseOnly Boolean @default(false)
  isActive            Boolean @default(true)

  // Regras avançadas: restrição por categoria, tag ou cliente
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])
  tagId      String?
  tag        Tag?      @relation(fields: [tagId], references: [id])
  userId     String?
  user       User?     @relation("ExclusiveCoupons", fields: [userId], references: [id])

  usages        CouponUsage[]
  reviewRewards ReviewReward[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@map("coupons")
}

enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

model CouponUsage {
  id       String @id @default(cuid())
  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId   String
  orderId  String?

  createdAt DateTime @default(now())

  @@index([couponId])
  @@index([userId])
  @@map("coupon_usages")
}

model FreeShippingRule {
  id            String  @id @default(cuid())
  zipCodeStart  String // 8 digits
  zipCodeEnd    String // 8 digits
  minOrderValue Float
  isActive      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("free_shipping_rules")
}

model OrderStatusHistory {
  id      String @id @default(cuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  fromStatus String?
  toStatus   String
  notes      String?
  createdBy  String? // userId que fez a transicao

  createdAt DateTime @default(now())

  @@index([orderId])
  @@map("order_status_history")
}

model Bundle {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  discount    Float // percentual de desconto (0-100)

  items BundleItem[]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("bundles")
}

model BundleItem {
  id        String @id @default(cuid())
  bundleId  String
  bundle    Bundle @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId String

  quantity Int @default(1)

  createdAt DateTime @default(now())

  @@unique([bundleId, productId])
  @@map("bundle_items")
}

model Payment {
  id      String        @id @default(cuid())
  orderId String
  method  String // pix, credit_card, boleto
  status  PaymentStatus @default(PENDING)

  externalId   String? @unique // ID do Mercado Pago
  amount       Float
  discount     Float   @default(0) // desconto por metodo de pagamento
  paidAmount   Float?
  paidAt       DateTime?
  webhookData  String? // JSON do ultimo webhook

  // Mercado Pago — dados específicos por método
  pixQrCode     String? @db.Text // base64 QR code image
  pixCopiaECola String? @db.Text // texto copia-e-cola PIX
  boletoUrl     String? // URL para visualizar/baixar boleto
  boletoBarcode String? // código de barras do boleto
  expiresAt     DateTime? // expiração (PIX: 30min, Boleto: 3 dias)
  installments  Int? // parcelas do cartão
  cardLastFour  String? // últimos 4 dígitos do cartão

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([externalId])
  @@map("payments")
}

model StockAuditLog {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  variationId String?
  variation   ProductVariation? @relation(fields: [variationId], references: [id], onDelete: Cascade)

  quantityBefore Int
  quantityAfter  Int
  delta          Int // +/- change
  reservedBefore Int?
  reservedAfter  Int?

  reason      String // ORDER_RESERVED, ORDER_CONFIRMED, ORDER_CANCELLED, PAYMENT_FAILED, ADMIN_ADJUSTMENT
  referenceId String? // orderId ou admin userId

  createdAt DateTime @default(now())

  @@index([productId])
  @@index([variationId])
  @@index([createdAt])
  @@map("stock_audit_logs")
}

model CheckoutLog {
  id        String   @id @default(cuid())
  orderId   String?
  userId    String?
  step      String // create_order, create_payment, payment_webhook, payment_status_check
  status    String // success, error
  method    String? // pix, credit_card, boleto
  request   String? @db.Text // JSON do request (sanitizado, sem tokens)
  response  String? @db.Text // JSON do response
  error     String? @db.Text // mensagem de erro + stack
  duration  Int? // ms
  ip        String?
  userAgent String?
  metadata  String? @db.Text // JSON extra (ex: MP payment ID, idempotency key)
  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([step])
  @@index([createdAt])
  @@map("checkout_logs")
}

model SeoMeta {
  id          String @id @default(cuid())
  entityType  String // product, category, brand, page, blog_post
  entityId    String
  title       String?
  description String?
  ogImage     String?
  keywords    String?
  canonical   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([entityType, entityId])
  @@map("seo_meta")
}

model BlogPost {
  id          String  @id @default(cuid())
  title       String
  slug        String  @unique
  excerpt     String?
  content     String
  coverImage  String?
  authorId    String
  isPublished Boolean @default(false)
  featured    Boolean @default(false)

  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([slug])
  @@index([isPublished])
  @@map("blog_posts")
}

model Page {
  id      String @id @default(cuid())
  title   String
  slug    String @unique
  content String

  isPublished Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@map("pages")
}

// ─── Atributos ──────────────────────────────────────────

model Attribute {
  id     String           @id @default(cuid())
  name   String           @unique
  slug   String           @unique
  values AttributeValue[]

  createdAt DateTime @default(now())

  @@index([slug])
  @@map("attributes")
}

model AttributeValue {
  id          String    @id @default(cuid())
  attributeId String
  attribute   Attribute @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String
  slug        String

  productAttributes ProductAttribute[]

  createdAt DateTime @default(now())

  @@unique([attributeId, slug])
  @@map("attribute_values")
}

model ProductAttribute {
  id               String         @id @default(cuid())
  productId        String
  product          Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeValueId String
  attributeValue   AttributeValue @relation(fields: [attributeValueId], references: [id])

  @@unique([productId, attributeValueId])
  @@index([productId])
  @@map("product_attributes")
}

// ─── Produtos Relacionados ──────────────────────────────

model RelatedProduct {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation("ProductRelated", fields: [productId], references: [id], onDelete: Cascade)
  type      String // "product", "tag", "category", "attribute"
  targetId  String // ID do produto/tag/categoria/atributo

  @@index([productId])
  @@map("related_products")
}

// ─── Avaliacoes ─────────────────────────────────────────

model Review {
  id        String  @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id])
  orderId   String
  rating    Int // 1-5
  comment   String?
  images    String? // JSON array de URLs

  isApproved Boolean      @default(false)
  reward     ReviewReward?

  createdAt DateTime @default(now())

  @@unique([productId, userId, orderId])
  @@index([productId])
  @@map("reviews")
}

model ReviewReward {
  id       String @id @default(cuid())
  reviewId String @unique
  review   Review @relation(fields: [reviewId], references: [id])
  couponId String
  coupon   Coupon @relation(fields: [couponId], references: [id])

  createdAt DateTime @default(now())

  @@map("review_rewards")
}

model WishlistItem {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model EmailTemplate {
  id   String @id @default(cuid())
  type String @unique // welcome, order-confirmation, status-change, password-reset, review-reward

  subject String // Assunto do email (suporta tags: {{nome_cliente}})
  htmlBody String @db.Text // Corpo HTML com tags: {{nome_cliente}}, {{numero_pedido}}, etc.

  // Tags disponíveis para este tipo (JSON array para referência no admin)
  availableTags String @db.Text // JSON: ["nome_cliente", "numero_pedido", ...]

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("email_templates")
}

model ShippingMethod {
  id          String  @id @default(cuid())
  serviceId   Int     @unique // ID do serviço no Melhor Envio (1=PAC, 2=SEDEX, etc.)
  name        String  // Nome original do Melhor Envio
  displayName String? // Nome editável exibido ao cliente (se null, usa name)
  company     String  // Transportadora (ex: "Correios", "Jadlog")
  extraDays   Int     @default(0) // Dias adicionais de prazo para este método
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shipping_methods")
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String

  @@map("settings")
}
